// Football-Picks data model.
// Three leagues (NFL, College FBS, Texas UIL 6A), a global pick'em pool,
// and picks scored straight-up (pick the winner) across all leagues.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum League {
  NFL
  CFB
  HS6A
}

enum GameStatus {
  SCHEDULED
  IN_PROGRESS
  FINAL
  CANCELED
}

// Which side a pick is on.
enum PickSide {
  HOME
  AWAY
}

// Outcome of a settled pick.
enum PickResult {
  PENDING
  WIN
  LOSS
  PUSH
  VOID
}

enum BracketStatus {
  SETUP // admin still seeding the field
  OPEN // picks accepted
  LOCKED // first game kicked off; no more picks
  COMPLETE // champion decided
}

enum SurvivorResult {
  PENDING
  WIN
  LOSS
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  // Nullable so the OAuth adapter (Google) can create a user before a username
  // is chosen; required at credential sign-up and enforced in the app.
  username      String?   @unique
  name          String?
  image         String?
  // Null for accounts created via Google with no password set.
  passwordHash  String?
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  picks               Pick[]
  accounts            Account[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  bracketPicks        BracketPick[]
  survivorPicks       SurvivorPick[]
}

// --- Auth.js (NextAuth) adapter models ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Single-use password reset tokens. Only the SHA-256 hash is stored; the raw
// token lives only in the emailed link.
model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// --- Postseason brackets (NFL & CFP) ---

model Bracket {
  id        String        @id @default(cuid())
  league    League
  season    Int
  title     String
  status    BracketStatus @default(SETUP)
  lockAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  entries BracketEntry[]
  games   BracketGame[]

  @@unique([league, season])
}

// A seeded team in the field. Identified within a bracket by (group, seed):
// group is the conference ("AFC"/"NFC") for NFL, null for the single CFP field.
model BracketEntry {
  id          String  @id @default(cuid())
  bracketId   String
  bracket     Bracket @relation(fields: [bracketId], references: [id], onDelete: Cascade)
  seed        Int
  group       String?
  displayName String

  @@unique([bracketId, group, seed])
  @@index([bracketId])
}

// A matchup slot in the tree. Each side is either a seeded entry (topSeed/
// topGroup) or the winner of an earlier slot (topFromSlot). The actual winner
// is recorded as (winnerSeed, winnerGroup). Cross-refs are plain values, not
// FKs, so deleting a bracket cleanly cascades without self-referential cycles.
model BracketGame {
  id        String  @id @default(cuid())
  bracketId String
  bracket   Bracket @relation(fields: [bracketId], references: [id], onDelete: Cascade)
  round     Int
  slot      Int
  group     String?
  label     String

  topSeed        Int?
  topGroup       String?
  topFromSlot    Int?
  bottomSeed     Int?
  bottomGroup    String?
  bottomFromSlot Int?

  winnerSeed  Int?
  winnerGroup String?

  picks BracketPick[]

  @@unique([bracketId, slot])
  @@index([bracketId])
}

model BracketPick {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  bracketGameId String
  bracketGame   BracketGame @relation(fields: [bracketGameId], references: [id], onDelete: Cascade)
  // Predicted winner of this slot, identified by (group, seed).
  predSeed      Int
  predGroup     String?
  correct       Boolean?
  points        Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([userId, bracketGameId])
  @@index([bracketGameId])
}

// --- Survivor / eliminator pool ---
// Each week pick one team to win (straight up); can't reuse a team; one loss
// and you're out. Uses existing Games of the pool's league/season.

model SurvivorPool {
  id        String         @id @default(cuid())
  league    League
  season    Int
  title     String
  active    Boolean        @default(true)
  createdAt DateTime       @default(now())
  picks     SurvivorPick[]

  @@unique([league, season])
}

model SurvivorPick {
  id     String       @id @default(cuid())
  poolId String
  pool   SurvivorPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  userId String
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  week   Int
  gameId String
  game   Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  teamId String
  team   Team         @relation(fields: [teamId], references: [id])
  result SurvivorResult @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([poolId, userId, week])
  @@index([gameId])
  @@index([poolId])
}

model Team {
  id           String  @id @default(cuid())
  league       League
  name         String  // e.g. "Cowboys", "Longhorns", "Westlake"
  displayName   String // e.g. "Dallas Cowboys", "Texas Longhorns", "Westlake Chaparrals"
  abbreviation String?
  location     String? // city / school location
  venue        String? // home stadium name (mainly HS)
  // Stable id from the source feed (ESPN/CFBD/etc), used for ingestion upserts.
  externalId   String?
  externalSource String?
  // For HS: UIL district. For CFB: conference. For NFL: division. Free-form.
  grouping     String?
  // Brand colors (hex without #), from the feed where available.
  color        String?
  altColor     String?
  logo         String? // team logo URL from the feed
  // Overall win/loss record summary from the feed, e.g. "7-2" (null if unknown).
  record       String?
  // Prior-season snapshot (NFL/CFB only): { season, record, leaders: [...] }.
  // Populated by scripts/load-season-summary.ts from ESPN. Null for HS.
  seasonSummary Json?

  homeGames     Game[]         @relation("HomeTeam")
  awayGames     Game[]         @relation("AwayTeam")
  survivorPicks SurvivorPick[]

  @@unique([league, externalSource, externalId])
  @@index([league])
}

model Game {
  id          String     @id @default(cuid())
  league      League
  season      Int
  week        Int?       // null for non-week-based contexts (e.g. some postseason)
  kickoff     DateTime
  // When picks lock for this game (kickoff for NFL/CFB; the Friday cutoff for HS).
  pickLockAt  DateTime
  status      GameStatus @default(SCHEDULED)

  homeTeamId String
  awayTeamId String
  homeTeam   Team   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team   @relation("AwayTeam", fields: [awayTeamId], references: [id])

  homeScore Int?
  awayScore Int?

  // Overrides the home team's stadium for neutral-site / relocated games.
  venue String?

  // Pregame betting line from the feed, e.g. "TCU -6.5" (spread) and the
  // over/under total. Null once unavailable; the last known line is kept.
  spread     String?
  overUnder  Float?

  externalId     String?
  externalSource String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  picks         Pick[]
  survivorPicks SurvivorPick[]

  @@unique([league, externalSource, externalId])
  @@index([league, season, week])
  @@index([kickoff])
}

model Pick {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameId String
  game   Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  side PickSide

  result        PickResult @default(PENDING)
  pointsAwarded Int        @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, gameId])
  @@index([gameId])
}
